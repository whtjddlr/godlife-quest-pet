# Local server
PORT=5173
APP_BASE_URL=http://localhost:5173

# Admin-only APIs
ADMIN_KEY=change-me-to-a-long-random-string

# Solar mission generation
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxx
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_SOLAR_MODEL=solar-pro3
AI_PRIMARY_PROVIDER=solar
AI_TRY_SECONDARY=false
AI_TIMEOUT_MS=4500

# Gemini mission generation
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
AI_DEBUG=false

# Supabase online database
# Project Settings > API에서 확인.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxx
SUPABASE_STATE_TABLE=user_states
SUPABASE_ROOM_TABLE=room_states
SUPABASE_ROOM_REGISTRY_MIRROR=false
SUPABASE_LEGACY_ROOM_REGISTRY=false
SUPABASE_TIMEOUT_MS=3000
REMOTE_USER_CACHE_MS=45000
REMOTE_ROOM_CACHE_MS=25000

# Legacy fallback keys, if your project still uses old anon/service_role keys.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct Postgres connection string, not required by this prototype.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# Image upload storage, for production later
STORAGE_PROVIDER=local
PUBLIC_UPLOAD_BASE_URL=https://your-domain.com/uploads
SUPABASE_STORAGE_BUCKET=proof-photos

# S3-compatible storage option
S3_BUCKET=
S3_REGION=ap-northeast-2
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Cloudinary option
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
